{
  "name": "charlesxmorrissey",
  "version": "0.1.0",
  "private": true,
  "browserslist": [
    "defaults"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "format": "prettier --write '**/*.{css,js,ts,tsx}' --loglevel error",
    "lint": "yarn lint:styles && yarn lint:js",
    "lint:fix": "eslint --ext .js,.ts,.tsx . --fix --max-warnings 0 .",
    "lint:js": "eslint --ext .js,.ts,.tsx .",
    "lint:styles": "stylelint --config stylelint.config.js 'src/**/*.css'",
    "type-check": "tsc -p .",
    "prepare": "husky install",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "next": "^12.0.2",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^12.0.2",
    "@svgr/webpack": "^5.5.0",
    "@swc/core": "^1.2.106",
    "@swc/jest": "^0.2.5",
    "@testing-library/dom": "^8.1.0",
    "@testing-library/jest-dom": "^5.14.1",
    "@testing-library/react": "^12.0.0",
    "@testing-library/user-event": "^13.1.9",
    "@types/jest": "^27.0.2",
    "@types/node": "^14.14.14",
    "@types/react": "^17.0.0",
    "@typescript-eslint/eslint-plugin": "^5.2.0",
    "@typescript-eslint/parser": "^5.2.0",
    "babel-jest": "^27.3.1",
    "eslint": "<8.0.0",
    "eslint-config-next": "^12.0.2",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-import-helpers": "^1.1.0",
    "eslint-plugin-jsdoc": "^37.0.3",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-react": "^7.26.1",
    "eslint-plugin-react-hooks": "^4.2.0",
    "husky": "^7.0.4",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^27.3.1",
    "postcss-custom-properties": "^10.0.0",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-nesting": "^7.0.1",
    "postcss-normalize": "^9.0.0",
    "postcss-preset-env": "^6.7.0",
    "prettier": "2.4.1",
    "prettier-plugin-jsdoc": "^0.3.23",
    "stylelint": "^14.0.1",
    "stylelint-config-css-modules": "^2.3.0",
    "stylelint-config-prettier": "^9.0.3",
    "stylelint-config-standard": "^23.0.0",
    "stylelint-order": "^5.0.0",
    "typescript": "^4.4.4"
  },
  "resolutions": {
    "sanitize.css": "12.0.1"
  }
}
