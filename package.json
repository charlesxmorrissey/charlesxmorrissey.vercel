{
  "name": "charlesxmorrissey",
  "version": "0.1.0",
  "private": true,
  "browserslist": [
    "defaults"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "format": "prettier --write '**/*.{css,js,ts,tsx}' --loglevel error",
    "lint": "yarn lint:styles && yarn lint:js",
    "lint:fix": "eslint --ext .js,.ts,.tsx . --fix --max-warnings 0 .",
    "lint:js": "eslint --ext .js,.ts,.tsx .",
    "lint:styles": "stylelint --config stylelint.config.js 'src/**/*.css'",
    "type-check": "tsc -p .",
    "prepare": "husky install"
  },
  "dependencies": {
    "next": "^11.0.1",
    "react": "^17.0.2",
    "react-dom": "^17.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.12.10",
    "@svgr/webpack": "^5.5.0",
    "@types/node": "^14.14.14",
    "@types/react": "^17.0.0",
    "@typescript-eslint/eslint-plugin": "^4.10.0",
    "@typescript-eslint/parser": "^4.10.0",
    "babel-plugin-module-resolver": "^4.1.0",
    "eslint": "^7.16.0",
    "eslint-config-next": "^11.0.1",
    "eslint-config-prettier": "^7.1.0",
    "eslint-import-resolver-babel-module": "^5.2.0",
    "eslint-import-resolver-typescript": "^2.3.0",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-import-helpers": "^1.1.0",
    "eslint-plugin-jsdoc": "^35.4.1",
    "eslint-plugin-jsx-a11y": "^6.4.1",
    "eslint-plugin-prettier": "^3.3.0",
    "eslint-plugin-react": "^7.21.5",
    "eslint-plugin-react-hooks": "^4.2.0",
    "husky": "6",
    "postcss-custom-properties": "^10.0.0",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-nesting": "^7.0.1",
    "postcss-normalize": "^9.0.0",
    "postcss-preset-env": "^6.7.0",
    "prettier": "2.3.0",
    "prettier-plugin-jsdoc": "^0.3.23",
    "stylelint": "^13.13.1",
    "stylelint-config-css-modules": "^2.2.0",
    "stylelint-config-prettier": "^8.0.2",
    "stylelint-config-standard": "^22.0.0",
    "stylelint-order": "^4.1.0",
    "typescript": "^4.1.3"
  }
}
